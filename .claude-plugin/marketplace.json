{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/schemas/plugin.json",
  "name": "gap-hunter",
  "version": "1.0.0",
  "description": "Multi-agent overnight research pattern that finds the blind spots before you build them. Sequential agent chain with a dedicated meta-agent for gap-finding, producing execution-ready briefings.",
  "author": {
    "name": "Gap-Hunter Pattern Contributors",
    "url": "https://github.com/0zoriginalss-ux/gap-hunter"
  },
  "homepage": "https://github.com/0zoriginalss-ux/gap-hunter",
  "repository": {
    "type": "git",
    "url": "https://github.com/0zoriginalss-ux/gap-hunter"
  },
  "license": "MIT",
  "keywords": [
    "research",
    "multi-agent",
    "planning",
    "architecture",
    "claude-code",
    "overnight-batch",
    "decision-records",
    "stakeholder-analysis"
  ],
  "commands": [
    {
      "name": "gap-hunt",
      "path": "commands/gap-hunt.md",
      "description": "Master command — routes to triage / explore / plan / validate based on argument"
    },
    {
      "name": "gap-hunt-triage",
      "path": "commands/gap-hunt-triage.md",
      "description": "Fast diagnostic — should you run this pattern, and which mode fits your situation?"
    },
    {
      "name": "gap-hunt-explore",
      "path": "commands/gap-hunt-explore.md",
      "description": "Reduced 3-agent chain for early-stage scope mapping"
    },
    {
      "name": "gap-hunt-plan",
      "path": "commands/gap-hunt-plan.md",
      "description": "Full 8-agent chain for pre-execution research with execution-ready briefings"
    },
    {
      "name": "gap-hunt-validate",
      "path": "commands/gap-hunt-validate.md",
      "description": "Post-wave hardening chain — reconcile research assumptions with execution reality"
    },
    {
      "name": "gap-hunt-resume",
      "path": "commands/gap-hunt-resume.md",
      "description": "Resume an interrupted run from the last completed agent"
    }
  ],
  "skills": [
    {
      "name": "gap-hunter",
      "path": "skills/gap-hunter/SKILL.md"
    }
  ],
  "agents": [
    { "name": "triage", "path": "agents/triage.md" },
    { "name": "wildcard-breadth", "path": "agents/wildcard-breadth.md" },
    { "name": "methodology", "path": "agents/methodology.md" },
    { "name": "orchestration", "path": "agents/orchestration.md" },
    { "name": "structure", "path": "agents/structure.md" },
    { "name": "stakeholder-sweep", "path": "agents/stakeholder-sweep.md" },
    { "name": "contradictions", "path": "agents/contradictions.md" },
    { "name": "gap-hunter", "path": "agents/gap-hunter.md" },
    { "name": "verifier", "path": "agents/verifier.md" },
    { "name": "consolidation", "path": "agents/consolidation.md" }
  ],
  "scripts": {
    "init": "scripts/init.sh",
    "smoke-test": "scripts/smoke-test.sh",
    "watchdog": "scripts/watchdog.sh",
    "resume": "scripts/resume.sh",
    "post-process": "scripts/post-process.sh"
  },
  "modes": {
    "triage": {
      "agents": ["triage"],
      "estimated_runtime": "10m"
    },
    "explore": {
      "agents": ["wildcard-breadth", "stakeholder-sweep", "gap-hunter", "verifier", "consolidation"],
      "estimated_runtime": "1-2h"
    },
    "plan": {
      "agents": ["wildcard-breadth", "methodology", "orchestration", "structure", "stakeholder-sweep", "contradictions", "gap-hunter", "verifier", "consolidation"],
      "estimated_runtime": "4-6h",
      "max_emergent_spawns": 3
    },
    "validate": {
      "agents": ["wildcard-breadth", "contradictions", "gap-hunter", "verifier", "consolidation"],
      "estimated_runtime": "2-3h",
      "delta_mode": true
    }
  },
  "adaptors": [
    "saas-feature",
    "ml-model",
    "hardware",
    "compliance-heavy",
    "generic"
  ]
}
